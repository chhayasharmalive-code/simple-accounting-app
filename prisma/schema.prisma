datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum TransactionType {
  GIVEN // User gave money to contact (Lent / Repaid to them)
  TAKEN // User took money from contact (Borrowed / Repaid by them)
}

model User {
  id           String        @id // Clerk User ID (user_...)
  email        String        @unique
  firstName    String?
  lastName     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contacts     Contact[]
  transactions Transaction[]
}

model Contact {
  id           String        @id @default(uuid())
  userId       String        // Owner of the contact
  name         String
  phone        String?
  avatar       String?       // Supports Base64 string or Cloud URL
  upiId        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id        String          @id @default(uuid())
  userId    String          // Owner of the transaction (for extra validation)
  contactId String          // Associated contact
  amount    Decimal         @db.Decimal(18, 2)
  type      TransactionType
  reference String?         // Description of transaction (e.g. "Lunch", "Repayment")
  createdAt DateTime        @default(now())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact   Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
}
